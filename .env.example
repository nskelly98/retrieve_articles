# OpenAI API key for article selection and summarization
OPENAI_API_KEY=sk-your-key-here

# Gmail SMTP credentials (requires 2FA + app password)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Where to send the daily email (defaults to GMAIL_ADDRESS if unset)
RECIPIENT_EMAIL=you@gmail.com

# Optional overrides
OPENAI_MODEL=gpt-4o-mini
LOOKBACK_DAYS=3
MAX_CANDIDATES=50
